#!/usr/bin/env node

import { execSync } from 'child_process';

try {
  execSync('node scripts/check-bom.mjs', { stdio: 'inherit' });
  process.exit(0);
} catch (error) {
  console.error('\n❌ Pre-commit check failed!');
  console.error('Files have been fixed. Please re-add them and commit again:');
  console.error('  git add -u');
  console.error('  git commit');
  process.exit(1);
}
